const BADGE_STYLES: Record<string, string> = {
  emerald: "bg-emerald-500/15 text-emerald-600 border-emerald-500/30 dark:text-emerald-300",
  violet:  "bg-violet-500/15 text-violet-600 border-violet-500/30 dark:text-violet-300",
  amber:   "bg-amber-500/15 text-amber-600 border-amber-500/30 dark:text-amber-300",
};

interface CyberItem {
  title: string; link: string; pubDate: string;
  source: string; sourceColor: string; tag: string;
}

function timeAgo(dateStr: string): string {
  if (!dateStr) return "";
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return "";
  const diff = (Date.now() - d.getTime()) / 1000;
  if (diff < 3600) return `${Math.floor(diff / 60)} min`;
  if (diff < 86400) return `${Math.floor(diff / 3600)} h`;
  return `${Math.floor(diff / 86400)} j`;
}

// ─── Composant principal ─────────────────────────────────────────────────────
export default function Home() {
  const { lang, setLang } = useLanguage();
  const { theme, toggleTheme } = useTheme();
  const isDark = theme === "dark";
  const h = homeStrings[lang];

  const [activeSection, setActiveSection]   = useState<string>("");
  const [showTop, setShowTop]               = useState(false);
  const [activeTheme, setActiveTheme]       = useState<string | null>(null);
  const [cyberItems, setCyberItems]         = useState<CyberItem[]>([]);
  const [cyberLoading, setCyberLoading]     = useState(true);

  const NAV_LINKS = [
    { label: h.nav.home,     href: "#top" },
    { label: h.nav.about,    href: "#about" },
    { label: h.nav.parcours, href: "#parcours" },
    { label: h.nav.projects, href: "#projects" },
    { label: lang === "fr" ? "Veille" : "News", href: "#veille" },
    { label: h.nav.contact,  href: "#contact" },
  ];

  // ── Cyber news ────────────────────────────────────────────────────────────
  const fetchCyber = useCallback(async () => {
    try {
      const res = await fetch("/api/cyber-watch");
      if (!res.ok) return;
      const data = await res.json();
      setCyberItems((data.items as CyberItem[]).slice(0, 6));
    } catch { /* silencieux */ } finally { setCyberLoading(false); }
  }, []);

  useEffect(() => { fetchCyber(); }, [fetchCyber]);

  // ── Scroll actif — throttlé RAF (1 update / frame, pas 60+ setState/sec) ──
  useEffect(() => {
    let rafId: number | null = null;

    const handleScroll = () => {
      if (rafId !== null) return;
      rafId = requestAnimationFrame(() => {
        rafId = null;
        const scrollY = window.scrollY;
        setShowTop(scrollY > 300);
        const atBottom = window.innerHeight + scrollY >= document.body.scrollHeight - 10;
        if (atBottom) { setActiveSection("contact"); return; }
        const ids = NAV_LINKS.map((l) => l.href.replace("#", ""));
        let current = "";
        for (const id of ids) {
          const el = document.getElementById(id);
          if (el && el.getBoundingClientRect().top <= 100) current = id;
        }
        if (current) setActiveSection(current);
      });
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll();
    return () => {
      window.removeEventListener("scroll", handleScroll);
      if (rafId !== null) cancelAnimationFrame(rafId);
    };
  // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [lang]);

  const scrollToSection = (e: React.MouseEvent<HTMLAnchorElement>, href: string) => {
    e.preventDefault();
    const id = href.replace("#", "");
    setActiveSection(id);
    if (id === "top") {
      window.scrollTo({ top: 0, behavior: "smooth" });
    } else {
      const el = document.getElementById(id);
      if (el) {
        const top = el.getBoundingClientRect().top + window.scrollY - 68;
        window.scrollTo({ top, behavior: "smooth" });
      }
    }
  };


  // ── Projets filtrés ───────────────────────────────────────────────────────
  const visibleProjects = activeTheme
    ? THEMES_DATA.find((t) => t.id === activeTheme)?.projects ?? []
    : THEMES_DATA.flatMap((t) => t.projects);

  // ── Rendu ─────────────────────────────────────────────────────────────────
  return (
    <main id="top" className="relative overflow-x-hidden">


      {/* ── NAVBAR — UNE SEULE BARRE, nowrap garanti ── */}
      <nav
        className="fixed top-0 inset-x-0 z-50 flex justify-center px-3"
        style={{ paddingTop: "max(0.625rem, env(safe-area-inset-top))" }}
      >
        <div
          className="flex items-center px-2 py-1.5 rounded-full border border-slate-200/80 bg-white/80 backdrop-blur-md shadow-sm dark:border-slate-700/60 dark:bg-slate-900/75"
          style={{ gap: "2px", flexWrap: "nowrap", maxWidth: "min(98vw, 900px)", overflowX: "auto", WebkitBackdropFilter: "blur(12px)" }}
        >
          {/* Liens nav */}
          {NAV_LINKS.map((link) => {
            const id = link.href.replace("#", "");
            const isActive = activeSection === id;
            return (
              <a
                key={link.href}
                href={link.href}
                onClick={(e) => scrollToSection(e, link.href)}
                className={`relative px-2.5 py-1.5 rounded-full text-[0.72rem] font-medium whitespace-nowrap flex-shrink-0 transition-all duration-200 ${
                  isActive
                    ? "text-blue-700 bg-blue-50/80 dark:text-blue-300 dark:bg-slate-700/60"
                    : "text-slate-500 hover:text-slate-800 hover:bg-slate-100/70 dark:text-slate-400 dark:hover:text-slate-200 dark:hover:bg-slate-800/60"
                }`}
              >
                {link.label}
                {isActive && (
                  <span className="absolute bottom-0.5 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full bg-blue-500 dark:bg-blue-400" />
                )}
              </a>
            );
          })}

          {/* Langue + Thème — masqués sur mobile (dock bas) */}
          <div className="nav-desktop-only flex-shrink-0" style={{ gap: "2px" }}>
            <div className="w-px h-4 bg-slate-200/80 dark:bg-slate-700/60 mx-1" />
            {LANGS.map((l) => {
              const active = l === lang;
              return (
                <button
                  key={l}
                  type="button"
                  onClick={() => setLang(l)}
                  className={`relative rounded-full px-2 py-1 text-[0.7rem] font-bold uppercase tracking-wider transition-colors ${
                    active
                      ? "text-slate-950 bg-emerald-400"
                      : "text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-slate-200"
                  }`}
                >
                  {l}
                </button>
              );
            })}
            <div className="w-px h-4 bg-slate-200/80 dark:bg-slate-700/60 mx-0.5" />
            <button
              type="button"
              onClick={toggleTheme}
              className="grid h-6 w-6 place-items-center rounded-full text-slate-600 hover:text-blue-600 transition-colors dark:text-slate-300 dark:hover:text-blue-300"
            >
              {isDark ? <SunIcon className="h-3.5 w-3.5" /> : <MoonIcon className="h-3.5 w-3.5" />}
            </button>
          </div>
        </div>
      </nav>

      {/* ── Bouton retour en haut ── */}
      <button
        onClick={() => window.scrollTo({ top: 0, behavior: "smooth" })}
        aria-label="Retour en haut"
        style={{ bottom: "max(1.5rem, calc(env(safe-area-inset-bottom) + 0.5rem))", right: "max(1.5rem, env(safe-area-inset-right))", WebkitBackdropFilter: "blur(12px)" }}
        className={`fixed z-50 p-3 rounded-full border border-slate-300/60 bg-white/80 text-slate-600 hover:text-blue-600 hover:border-blue-400 backdrop-blur shadow-lg transition-all duration-300 dark:border-slate-700/60 dark:bg-slate-800/80 dark:text-slate-300 dark:hover:text-blue-300 dark:hover:border-blue-400 ${
          showTop ? "opacity-100 translate-y-0" : "opacity-0 translate-y-4 pointer-events-none"
        }`}
      >
        <ArrowUpIcon className="w-4 h-4" />
      </button>

      {/* ── Dock mobile : langue + thème — visible seulement sur mobile ── */}
      <div
        className="nav-mobile-only fixed z-50 flex items-center gap-1 px-3 py-2 rounded-full border border-slate-200/80 bg-white/90 backdrop-blur-md shadow-lg dark:border-slate-700/60 dark:bg-slate-900/85"
        style={{
          bottom: "max(1.5rem, calc(env(safe-area-inset-bottom) + 0.5rem))",
          left: "max(1rem, env(safe-area-inset-left))",
          WebkitBackdropFilter: "blur(12px)",
        }}
      >
        {LANGS.map((l) => {
          const active = l === lang;
          return (
            <button
              key={l}
              type="button"
              onClick={() => setLang(l)}
              className={`rounded-full px-3 py-1.5 text-[0.72rem] font-bold uppercase tracking-wider transition-colors ${
                active
                  ? "text-slate-950 bg-emerald-400"
                  : "text-slate-500 dark:text-slate-400"
              }`}
            >
              {l}
            </button>
          );
        })}
        <div className="w-px h-4 bg-slate-200/80 dark:bg-slate-700/60 mx-0.5" />
        <button
